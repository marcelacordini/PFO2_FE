{
  "version": 2,
  "builds": [
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/agent1-codex", "dest": "/agent1-codex/index.html" },
    { "src": "/agent2-claude", "dest": "/agent2-claude/index.html" },
    { "src": "/prompt", "dest": "/prompt.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}